{
    "name": "dartvadius/eloquent-search",
    "description": "Universal JSON query DSL parser for Laravel Eloquent",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "DartVadius",
            "homepage": "https://github.com/DartVadius"
        }
    ],
    "keywords": ["laravel", "eloquent", "search", "filter", "json", "dsl", "query-builder"],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.0",
        "illuminate/support": "^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "DartVadius\\EloquentSearch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DartVadius\\EloquentSearch\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DartVadius\\EloquentSearch\\SearchServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
